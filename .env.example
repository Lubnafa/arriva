PORT=3000
NODE_ENV=development
API_KEY_SALT=replace-with-long-random-secret-min-16-chars
MEMBER_SERVICE_URL=https://members.example.internal
MEMBER_SERVICE_TIMEOUT=3000
PARTNER_CONFIG_URL=https://partners.example.internal
PARTNER_CONFIG_TIMEOUT=2000
PARTNER_CONFIG_CACHE_TTL_MS=300000
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# Reverse-proxy hops (0 = off). Set to 1 behind one ALB/nginx when using X-Forwarded-For.
TRUST_PROXY_HOPS=0
# Browser CORS: comma-separated origins, e.g. https://app.example.com. Empty in dev uses *; empty in staging/prod disables wildcard.
MCP_CORS_ORIGINS=
# Only when TLS is guaranteed for clients (e.g. HTTPS everywhere). Leave false for local HTTP.
HSTS_ENABLED=false
JSON_BODY_LIMIT=256kb
